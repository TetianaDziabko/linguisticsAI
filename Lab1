def decode_batch_predictions(pred):
    """
    Перетворює вихід моделі у текст і прибирає [UNK].
    """
    input_len = np.ones(pred.shape[0]) * pred.shape[1]

    results = keras.backend.ctc_decode(
        pred,
        input_length=input_len,
        greedy=False,
        beam_width=10
    )[0][0]

    output_text = []

    for res in results:
        res = tf.gather(res, tf.where(res != -1))
        res = tf.squeeze(res, axis=1)

        chars = num_to_char(res)
        text = tf.strings.reduce_join(chars).numpy().decode("utf-8")

        # прибираємо службовий токен
        text = text.replace("[UNK]", "")
        output_text.append(text)

    return output_text

def char_accuracy(true_list, pred_list):
    """
    Обчислює посимвольну точність з вирівнюванням довжин.
    """
    total_chars = 0
    correct_chars = 0

    for true_word, pred_word in zip(true_list, pred_list):
        max_len = max(len(true_word), len(pred_word))
        total_chars += max_len

        true_padded = list(true_word) + [""] * (max_len - len(true_word))
        pred_padded = list(pred_word) + [""] * (max_len - len(pred_word))

        for tc, pc in zip(true_padded, pred_padded):
            if tc == pc:
                correct_chars += 1

    if total_chars == 0:
        return 0.0

    return correct_chars / total_chars

