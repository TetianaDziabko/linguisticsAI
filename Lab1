class CTCLayer(layers.Layer):
    """
    Шар для обчислення CTC-loss.
    Реальна довжина міток рахується без паддінгу.
    """
    def __init__(self, **kwargs):
        super().__init__(**kwargs)
        self.loss_fn = keras.backend.ctc_batch_cost

    def call(self, y_true, y_pred):
        batch_len = tf.cast(tf.shape(y_true)[0], dtype="int64")
        input_length = tf.cast(tf.shape(y_pred)[1], dtype="int64")

        # Реальна довжина міток: рахуємо кількість непорожніх токенів
        # Паддінг у StringLookup + padded_batch заповнюється нулями
        label_length = tf.math.count_nonzero(y_true, axis=1, keepdims=True, dtype="int64")

        input_length = input_length * tf.ones(shape=(batch_len, 1), dtype="int64")

        loss = self.loss_fn(y_true, y_pred, input_length, label_length)
        self.add_loss(loss)

        return y_pred

# ============================================================
# 7. ПОБУДОВА OCR-МОДЕЛІ
# ============================================================

def build_model():
    input_img = layers.Input(
        shape=(IMG_WIDTH, IMG_HEIGHT, 1),
        name="image",
        dtype="float32"
    )

    labels_input = layers.Input(
        name="label",
        shape=(None,),
        dtype="int64"
    )

    # CNN
    x = layers.Conv2D(64, (3, 3), activation="relu", padding="same")(input_img)
    x = layers.MaxPooling2D((2, 2))(x)

    x = layers.Conv2D(128, (3, 3), activation="relu", padding="same")(x)
    x = layers.MaxPooling2D((2, 2))(x)

    # Перехід до послідовності
    new_shape = (IMG_WIDTH // 4, (IMG_HEIGHT // 4) * 128)
    x = layers.Reshape(target_shape=new_shape)(x)

    x = layers.Dense(256, activation="relu")(x)
    x = layers.Dropout(0.2)(x)

    x = layers.Bidirectional(layers.LSTM(256, return_sequences=True))(x)
    x = layers.Bidirectional(layers.LSTM(128, return_sequences=True))(x)

    x = layers.Dense(
        len(char_to_num.get_vocabulary()) + 1,
        activation="softmax",
        name="dense2"
    )(x)

    output = CTCLayer(name="ctc_loss")(labels_input, x)

    model = keras.models.Model(
        inputs=[input_img, labels_input],
        outputs=output,
        name="iam_word_ocr_model"
    )

    optimizer = keras.optimizers.Adam(learning_rate=0.0003)
    model.compile(optimizer=optimizer)
    return model


