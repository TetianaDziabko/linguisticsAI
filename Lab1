def get_image_path(words_folder: str, image_id: str) -> str:
    """
    Формує шлях до png-файлу за image_id.
    Наприклад:
    a01-000u-00-00 -> words/a01/a01-000u/a01-000u-00-00.png
    """
    parts = image_id.split("-")
    folder1 = parts[0]
    folder2 = f"{parts[0]}-{parts[1]}"
    return os.path.join(words_folder, folder1, folder2, image_id + ".png")


def is_valid_image(image_path: str) -> bool:
    """
    Перевіряє, чи файл:
    - існує,
    - не порожній,
    - відкривається як зображення.
    """
    try:
        if not os.path.exists(image_path):
            return False

        if os.path.getsize(image_path) == 0:
            return False

        with Image.open(image_path) as img:
            img.verify()

        return True
    except Exception:
        return False


def load_iam_words(words_txt_path: str, words_folder: str, max_samples=None):
    """
    Зчитує words.txt, бере лише записи зі статусом 'ok',
    перевіряє зображення і повертає:
    image_paths, labels
    """
    image_paths = []
    labels = []
    skipped = 0

    with open(words_txt_path, "r", encoding="utf-8") as f:
        for line in f:
            line = line.strip()

            if not line or line.startswith("#"):
                continue

            parts = line.split()

            if len(parts) < 9:
                skipped += 1
                continue

            image_id = parts[0]
            status = parts[1]

            if status != "ok":
                continue

            label = " ".join(parts[8:])
            image_path = get_image_path(words_folder, image_id)

            if is_valid_image(image_path):
                image_paths.append(image_path)
                labels.append(label)
            else:
                skipped += 1

            if max_samples is not None and len(image_paths) >= max_samples:
                break

    print(f"Коректних зображень: {len(image_paths)}")
    print(f"Пропущено пошкоджених/порожніх файлів: {skipped}")

    return image_paths, labels


