def show_image(image_path, title="Зображення"):
    """
    Показує оригінальне зображення.
    """
    img = Image.open(image_path).convert("L")
    plt.figure(figsize=(8, 3))
    plt.imshow(img, cmap="gray")
    plt.title(title)
    plt.axis("off")
    plt.show()


def preprocess_image_for_display(image_path):
    """
    Повертає оброблене зображення у вигляді numpy-масиву,
    щоб показати, що саме бачить модель.
    """
    img = tf.io.read_file(image_path)
    img = tf.io.decode_image(img, channels=1, expand_animations=False)
    img.set_shape([None, None, 1])

    img = tf.image.convert_image_dtype(img, tf.float32)

    # Обрізаємо слово
    img = crop_word_region(img)

    # Resize + padding
    img = distortion_free_resize(img, img_size=(IMG_WIDTH, IMG_HEIGHT))

    # Транспонування
    img = tf.transpose(img, perm=[1, 0, 2])

    return img.numpy().squeeze()

def show_original_and_processed(image_path):
    """
    Показує оригінальне та оброблене зображення поруч.
    """
    original = Image.open(image_path).convert("L")
    processed = preprocess_image_for_display(image_path)

    plt.figure(figsize=(12, 4))

    plt.subplot(1, 2, 1)
    plt.imshow(original, cmap="gray")
    plt.title("Оригінальне зображення")
    plt.axis("off")

    plt.subplot(1, 2, 2)
    plt.imshow(processed, cmap="gray")
    plt.title("Після попередньої обробки")
    plt.axis("off")

    plt.tight_layout()
    plt.show()


def predict_and_show(image_path):
    """
    Показує зображення і прогноз моделі.
    """
    if not is_valid_image(image_path):
        raise ValueError(f"Некоректне або пошкоджене зображення: {image_path}")

    prediction = predict_single_image(image_path)

    show_original_and_processed(image_path)
    print(f"Прогноз моделі: {prediction}")


def show_test_predictions(num_samples=5):
    """
    Показує кілька прикладів із тестової вибірки:
    зображення, правильне слово і прогноз моделі.
    """
    num_samples = min(num_samples, len(test_paths))

    plt.figure(figsize=(12, num_samples * 2.5))

    for i in range(num_samples):
        image_path = test_paths[i]
        true_label = test_labels[i]
        pred_label = predict_single_image(image_path)

        img = Image.open(image_path).convert("L")

        plt.subplot(num_samples, 1, i + 1)
        plt.imshow(img, cmap="gray")
        plt.title(f"True: {true_label} | Pred: {pred_label}")
        plt.axis("off")

    plt.tight_layout()
    plt.show()

